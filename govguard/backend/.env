# GovGuard™ Backend Environment Variables
# NEVER commit this file to version control

# Application
ENVIRONMENT=development
SECRET_KEY=dev-secret-key-change-in-production-must-be-32-chars

# Database (overridden by docker-compose)
DATABASE_URL=postgresql+asyncpg://govguard_app:devpass_change_in_prod@localhost:5432/govguard

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/2
CELERY_RESULT_BACKEND=redis://localhost:6379/3

# AWS (configure for your account)
AWS_REGION=us-gov-west-1
# AWS_ACCESS_KEY_ID=your-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-key

# Cognito (configure for your User Pool)
COGNITO_USER_POOL_ID=us-gov-west-1_XXXXXXXXX
COGNITO_CLIENT_ID=your-cognito-client-id
COGNITO_DOMAIN=govguard.auth.us-gov-west-1.amazoncognito.com

# S3 Buckets
S3_EVIDENCE_BUCKET=govguard-evidence-dev
S3_UPLOADS_BUCKET=govguard-uploads-dev
S3_EXPORTS_BUCKET=govguard-exports-dev
S3_ML_BUCKET=govguard-ml-dev

# OpenSearch
OPENSEARCH_URL=http://localhost:9200

# Stripe (get from Stripe dashboard)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# SAM.gov (apply at api.sam.gov)
# SAM_GOV_API_KEY=your-api-key

# CORS
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]
