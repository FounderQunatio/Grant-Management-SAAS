# ════════════════════════════════════════════════════════════
# GovGuard™ — Environment Variables
# Copy to .env.local for development, set in Vercel for prod
# ════════════════════════════════════════════════════════════

# ── DATABASE (Neon PostgreSQL) ─────────────────────────────
# Get from: https://console.neon.tech → Connection string
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/govguard?sslmode=require"

# ── AUTH0 ──────────────────────────────────────────────────
# Get from: https://manage.auth0.com → Applications → Your App
AUTH0_SECRET="use-openssl-rand-hex-32-to-generate"
AUTH0_BASE_URL="https://your-app.vercel.app"
AUTH0_ISSUER_BASE_URL="https://your-tenant.us.auth0.com"
AUTH0_CLIENT_ID="your-auth0-client-id"
AUTH0_CLIENT_SECRET="your-auth0-client-secret"
AUTH0_AUDIENCE="https://govguard-api"
AUTH0_SCOPE="openid profile email"

# ── APP ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
NEXT_PUBLIC_APP_NAME="GovGuard™"
NODE_ENV="production"

# ── STRIPE (optional for billing) ─────────────────────────
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."

# ── EMAIL (Resend) ─────────────────────────────────────────
# RESEND_API_KEY="re_..."
# RESEND_FROM_EMAIL="noreply@yourdomain.com"
